cells:
  - kind: 2
    value: "CREATE TABLE Departments(\r

      \    DEPARTMENT_ID INT PRIMARY KEY, \r

      \    DEPARTMENT_NAME VARCHAR2(50),\r

      \    OFFICE_LOCATION VARCHAR2(50)\r

      );\r

      \r

      CREATE TABLE Students (\r

      \    STUDENT_ID INT PRIMARY KEY,\r

      \    STUDENT_NAME VARCHAR(50),\r

      \    AGE INT,\r

      \    EMAIL VARCHAR(60),\r

      \    DEPARTMENT_ID INT,\r

      \    STATUS VARCHAR(20),\r

      \    FOREIGN KEY (Department_ID) REFERENCES Departments(Department_ID)\r

      );\r

      \r

      CREATE TABLE Teachers(\r

      \    TEACHER_ID INT PRIMARY KEY,\r

      \    TEACHER_NAME VARCHAR2(50),\r

      \    EMAIL VARCHAR2(60),\r

      \    DEPARTMENT_ID INT,\r

      \    FOREIGN KEY (DEPARTMENT_ID) REFERENCES Departments(DEPARTMENT_ID)\r

      );\r

      \r

      CREATE TABLE Courses(\r

      \    COURSE_ID INT PRIMARY KEY,\r

      \    COURSE_NAME VARCHAR2(50),\r

      \    CREDIT_HOURS INT, \r

      \    DEPARTMENT_ID INT,\r

      \    FOREIGN KEY (DEPARTMENT_ID) REFERENCES Departments(DEPARTMENT_ID)\r

      );\r

      \r

      CREATE TABLE Enrollment(\r

      \    ENROLLMENT_ID INT PRIMARY KEY, \r

      \    STUDENT_ID INT, \r

      \    COURSE_ID INT ,\r

      \    ENROLL_DATE DATE,\r

      \    FOREIGN KEY (STUDENT_ID) REFERENCES Students(STUDENT_ID),\r

      \    FOREIGN KEY (COURSE_ID) REFERENCES Courses (COURSE_ID)\r

      );\r

      \r\n"
    languageId: oracle-sql
  - kind: 2
    value: "INSERT INTO Departments VALUES(1, 'Finance', 'Upper Deck');\r

      INSERT INTO Departments VALUES(2, 'Marketing', 'Skybox');\r

      INSERT INTO Departments VALUES(3, 'IT', 'BB Court');"
    languageId: oracle-sql
  - kind: 2
