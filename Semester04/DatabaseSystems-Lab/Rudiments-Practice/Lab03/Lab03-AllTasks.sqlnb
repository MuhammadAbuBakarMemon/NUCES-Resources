  - kind: 2
    value: "-- Question Number 02 \r

      \r

      ALTER TABLE Students \r

      ADD PhoneNumber VARCHAR2(15);"
    languageId: oracle-sql
  - kind: 2
    value: "--3. Modify the Email column size in Teachers table to 80 characters.\r

      \r

      ALTER TABLE Teachers \r

      MODIFY EMAIL VARCHAR2(80);"
    languageId: oracle-sql
  - kind: 2
    value: "--4. Rename table Teachers to Instructors.\r

      \r

      RENAME Teachers TO Instructors;"
    languageId: oracle-sql
  - kind: 2
    value: "--5. Add a CHECK constraint to ensure Age ≤ 30.\r

      \r

      ALTER TABLE Students \r

      ADD CONSTRAINT chk_age CHECK(AGE <= 30);"
    languageId: oracle-sql
  - kind: 2
    value: "--6. Insert a new student who belongs to Computer Science department.\r

      \r

      INSERT INTO Departments VALUES(4, 'Computer Science', 'Pull ke peeche');\r

      \r

      INSERT INTO Students VALUES(4, 'Usman',32 , 'us@hotmail.com', 4,
      'Active');"
    languageId: oracle-sql
  - kind: 2
    value: "SELECT * FROM DEPARTMENTS;\r

